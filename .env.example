# Generate a jwk-formatted AES-CBC key (for SECRET_CLIENT_COOKIE_VAR), e.g. by running
# crypto.subtle
#   .generateKey(
#     { name: "AES-CBC", length: 256 },
#     true,
#     ["encrypt", "decrypt"]
#   )
#   .then((key) => crypto.subtle.exportKey("jwk", key))
#   .then(JSON.stringify)
#   .then(console.log);
SECRET_CLIENT_COOKIE_VAR="{\"key_ops\":[\"encrypt\",\"decrypt\"],\"ext\":true,\"kty\":\"oct\",\"k\":\"...\",\"alg\":\"A256CBC\"}"

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Postgres
# postgresql://user:password@host:port/dbname
DATABASE_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Allowed emails (comma-separated)
ALLOWED_EMAILS=

# OpenAI (embeddings / recommendations)
OPENAI_API_KEY=

# Local Redis on VPS (caching)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# TMDB (video search/create) – set at least one
# TMDB_ACCESS_TOKEN=
# TMDB_API_KEY=

# IMDB enrichment via Crawlee (set to true to enable; requires Playwright)
# IMDB_ENRICH_ENABLED=false

# Cloudinary (image upload)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_FOLDER=tagall
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Open Library (books) – no key required; the contact email raises the rate limit
# from 1 to 3 requests/second and is sent in the User-Agent header
OPEN_LIBRARY_CONTACT_EMAIL=
